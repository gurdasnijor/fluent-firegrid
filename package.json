{
  "name": "fluent-firegrid",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check --continue --output-logs=errors-only",
    "diagnostics": "turbo run diagnostics --continue --output-logs=errors-only",
    "format": "oxlint --fix && dprint fmt",
    "lint": "oxlint -f unix && dprint check",
    "lint:dead": "knip --production --workspace './packages/*' --include files,exports,nsExports,types,nsTypes,enumMembers,namespaceMembers,duplicates --treat-config-hints-as-errors && knip --workspace './packages/*' --include files,exports,nsExports,types,nsTypes,enumMembers,namespaceMembers,duplicates,dependencies,unlisted,unresolved,binaries,catalog --treat-config-hints-as-errors",
    "lint:deps": "depcruise --config .dependency-cruiser.cjs packages",
    "lint:dup": "jscpd packages/*/src",
    "lint:fix": "oxlint --fix && dprint fmt",
    "lint:root": "oxlint -f unix tools/oxc/oxlint-plugin.js",
    "preflight": "pnpm run check",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "verify": "pnpm run check"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "dependency-cruiser": "^17.4.0",
    "jscpd": "^4.0.9",
    "knip": "^6.11.0",
    "dprint": "^0.54.0",
    "oxlint": "1.42.0",
    "turbo": "^2.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.0"
  }
}
