{
  "name": "fluent-firegrid",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "lint": "eslint . --max-warnings 0 --cache --cache-location .eslintcache",
    "format": "eslint . --fix",
    "lint:dead": "knip --treat-config-hints-as-errors",
    "lint:deps": "depcruise --config .dependency-cruiser.cjs packages",
    "lint:dup": "jscpd packages/*/src",
    "lint:effect": "eslint packages --config eslint.config.effect-advisory.mjs",
    "typecheck": "turbo run typecheck --filter='@firegrid/fluent-*' --filter=firelab",
    "test": "turbo run test --filter='@firegrid/fluent-*'",
    "build": "turbo run build --filter='@firegrid/fluent-*' --filter=firelab",
    "diagnostics": "turbo run diagnostics --filter='@firegrid/fluent-*'",
    "typespec:compile": "tsp compile .",
    "typespec:scaffold": "tsp compile . --config tspconfig.scaffold.yaml",
    "typespec:scaffold:clean": "rm -rf tsp-output/scaffold-server",
    "typespec:import:electric": "tsp-openapi3 openapi/electric-api.yaml --output-dir tsp-output/electric-api --namespace ElectricAPI",
    "openapi:mock": "prism mock openapi/durable-streams.yaml --host 127.0.0.1 --port 4010",
    "openapi:view": "node scripts/openapi-viewer.mjs",
    "openapi:dev": "node scripts/openapi-dev.mjs",
    "preflight": "turbo run lint lint:dead lint:dup lint:deps --continue --output-logs=errors-only; L=$?; pnpm run typecheck; T=$?; pnpm run test; E=$?; pnpm run diagnostics; D=$?; pnpm run typespec:compile; P=$?; exit $((L|T|E|D|P))",
    "verify": "pnpm run preflight"
  },
  "devDependencies": {
    "@codeforbreakfast/eslint-effect": "0.8.5",
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.86.2",
    "@eslint/js": "^10.0.1",
    "@stoplight/prism-cli": "5.15.11",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typespec/compiler": "^1.13.0",
    "@typespec/events": "^0.83.0",
    "@typespec/http": "^1.13.0",
    "@typespec/http-server-js": "0.58.0-alpha.27",
    "@typespec/openapi": "^1.13.0",
    "@typespec/openapi3": "^1.13.0",
    "@typespec/rest": "^0.83.0",
    "@typespec/sse": "^0.83.0",
    "@typespec/streams": "^0.83.0",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^10.3.0",
    "eslint-plugin-functional": "^10.0.0",
    "globals": "^17.6.0",
    "jscpd": "^4.0.9",
    "knip": "^6.11.0",
    "tslib": "^2.8.1",
    "turbo": "^2.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^3.2.0"
  }
}
