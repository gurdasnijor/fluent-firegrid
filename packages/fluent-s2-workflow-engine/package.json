{
  "name": "@firegrid/fluent-s2-workflow-engine",
  "version": "0.0.0",
  "description": "S2-native WorkflowEngine implementation for Firegrid.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
