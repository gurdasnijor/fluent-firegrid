  },
  "peerDependencies": {
    "effect": ">=4.0.0-beta.75 <5"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "effect": "4.0.0-beta.78",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
