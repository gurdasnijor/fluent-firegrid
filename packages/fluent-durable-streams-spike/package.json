{
  "name": "@firegrid/fluent-durable-streams-spike",
  "version": "0.0.0",
  "description": "Same-process Durable Streams client/server spike over the stream-log ADT.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "benchmark:backends": "tsx scripts/benchmark-backends.ts",
    "diagnostics": "effect-language-service diagnostics --project tsconfig.json --severity error",
    "test": "vitest run --root ../.. --project fluent-durable-streams-spike",
    "test:conformance": "tsx scripts/conformance.ts",
    "test:conformance:s2-lite": "tsx scripts/conformance-s2-lite.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/platform-node": "https://pkg.pr.new/Effect-TS/effect-smol/@effect/platform-node@c710049d5812e68a2d935f2a05b4dcb7337a32af",
    "@firegrid/fluent-stream-log": "workspace:*",
    "effect": "https://pkg.pr.new/Effect-TS/effect-smol/effect@c710049d5812e68a2d935f2a05b4dcb7337a32af"
  },
  "devDependencies": {
    "@durable-streams/client": "0.2.6",
    "@durable-streams/server": "0.3.7",
    "@effect/opentelemetry": "4.0.0-beta.78",
    "@firegrid/fluent-stream-log-inmemory": "workspace:*",
    "@firegrid/fluent-stream-log-s2-lite": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.208.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-logs": "^0.208.0",
    "@opentelemetry/sdk-metrics": "^2.2.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/sdk-trace-web": "^2.2.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
