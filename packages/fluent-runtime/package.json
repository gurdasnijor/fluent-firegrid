{
  "name": "@firegrid/fluent-runtime",
  "version": "0.0.0",
  "description": "Managed-agent runtime workbench over Effect and Durable Streams.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./acp": {
      "types": "./src/acp/index.ts",
      "default": "./src/acp/index.ts"
    },
    "./acp-conductor": {
      "types": "./src/acp-conductor/index.ts",
      "default": "./src/acp-conductor/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "diagnostics": "effect-language-service diagnostics --project tsconfig.json --strict",
    "overview": "effect-language-service overview --project tsconfig.json",
    "build": "tsc",
    "test": "vitest run --root ../.. --project fluent-runtime",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.22.0",
    "@effect/platform": "^0.96.1",
    "@marcbachmann/cel-js": "7.6.1",
    "effect": "^3.21.2",
    "effect-durable-client": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
