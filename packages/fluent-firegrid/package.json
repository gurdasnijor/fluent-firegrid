{
  "name": "@firegrid/fluent-firegrid",
  "version": "0.0.0",
  "description": "Effect-native Firegrid primitives with named durable steps over Durable Streams.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "examples",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "bench": "vitest bench bench",
    "diagnostics": "effect-language-service diagnostics --project tsconfig.json --strict",
    "overview": "effect-language-service overview --project tsconfig.json",
    "build": "tsc",
    "check": "pnpm run typecheck && pnpm run test",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "effect": "^3.21.2",
    "effect-durable-streams": "workspace:*"
  },
  "devDependencies": {
    "@effect/platform": "^0.96.1",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
