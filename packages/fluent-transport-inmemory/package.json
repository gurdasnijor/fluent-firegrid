{
  "name": "@firegrid/fluent-transport-inmemory",
  "version": "0.0.0",
  "description": "In-memory protocol-agnostic transport for Fluent.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "diagnostics": "effect-language-service diagnostics --project tsconfig.json --severity error",
    "test": "vitest run --root ../.. --project fluent-transport-inmemory",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@firegrid/fluent-transport": "workspace:*",
    "effect": "4.0.0-beta.78"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
