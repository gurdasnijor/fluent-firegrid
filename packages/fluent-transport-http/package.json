{
  "name": "@firegrid/fluent-transport-http",
  "version": "0.0.0",
  "description": "HTTP transport implementation for Fluent transport messages.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "diagnostics": "effect-language-service diagnostics --project tsconfig.json --severity error",
    "test": "vitest run --root ../.. --project fluent-transport-http",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/experimental": "^0.60.0",
    "@effect/platform": "^0.96.1",
    "effect": "^3.21.2"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
