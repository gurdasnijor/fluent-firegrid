{
  "name": "effect-durable-client",
  "version": "0.0.0",
  "description": "Effect-native client for the Durable Streams Protocol: Stream-shaped reads, Sink-shaped writes, schema-validated decode/encode boundaries.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./CEL": {
      "types": "./src/CEL.ts",
      "default": "./src/CEL.ts"
    },
    "./Subscription": {
      "types": "./src/Subscription.ts",
      "default": "./src/Subscription.ts"
    }
  },
  "files": [
    "src",
    "docs",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "diagnostics": "effect-language-service diagnostics --project tsconfig.diagnostics.json --strict",
    "overview": "effect-language-service overview --project tsconfig.json",
    "build": "tsc",
    "check": "pnpm run typecheck && pnpm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/unit",
    "test:conformance": "vitest run test/conformance",
    "bench": "vitest bench --run test/bench",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@effect/platform": "^0.96.0",
    "effect": "^3.18.0"
  },
  "dependencies": {
    "eventsource-parser": "^3.0.0"
  },
  "devDependencies": {
    "@durable-streams/client": "0.2.6",
    "@durable-streams/server": "0.3.7",
    "@effect/platform": "^0.96.1",
    "@types/node": "^22.10.0",
    "effect": "^3.21.2",
    "expect-type": "^1.1.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
