{
  "name": "@firegrid/fluent-acp-process",
  "version": "0.0.0",
  "description": "ACP harness process owner: spawn/kill an ACP agent and expose its acp.Stream. Firegrid's FiregridAcpClient (separate fluent-runtime lane) wraps the stream.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": ["src", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "diagnostics": "effect-language-service diagnostics --project tsconfig.json --strict",
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.22.0",
    "@effect/platform": "^0.96.1",
    "effect": "^3.21.2"
  },
  "devDependencies": {
    "@effect/platform-node": "^0.106.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
