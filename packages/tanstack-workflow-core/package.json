{
  "name": "@tanstack/workflow-core",
  "version": "0.0.3",
  "description": "Vendored TanStack Workflow core engine.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    }
  },
  "files": ["src"],
  "scripts": {
    "build": "tsc",
    "lint": "oxlint -f unix --config ../../.oxlintrc.json -A effect/restricted-syntax -A promise/no-multiple-resolved .",
    "test": "vitest run --root ../.. --project tanstack-workflow-core --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "effect": "4.0.0-beta.87"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
