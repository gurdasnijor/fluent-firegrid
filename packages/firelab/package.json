{
  "name": "firelab",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/types.ts",
  "types": "./src/types.ts",
  "exports": {
    ".": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "diagnostics": "effect-language-service diagnostics --project tsconfig.json --strict",
    "validate": "tsx src/index.ts",
    "validate:list": "tsx src/index.ts list",
    "validate:run": "tsx src/index.ts run",
    "validate:all": "tsx src/index.ts run-all",
    "validate:runs": "tsx src/index.ts runs",
    "validate:show": "tsx src/index.ts show",
    "validate:perf": "tsx src/index.ts perf",
    "validate:gaps": "tsx src/index.ts gaps",
    "validate:seams": "tsx src/index.ts seams",
    "validate:proofs": "tsx src/index.ts proofs"
  },
  "dependencies": {
    "@effect/opentelemetry": "4.0.0-beta.78",
    "@effect/platform-node": "4.0.0-beta.78",
    "@marcbachmann/cel-js": "7.6.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.208.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-logs": "^0.208.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@opentelemetry/sdk-trace-web": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "effect": "4.0.0-beta.78",
    "effect-s2": "workspace:*",
    "effect-s2-durable": "workspace:*",
    "effect-s2-stream-db": "workspace:*",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
