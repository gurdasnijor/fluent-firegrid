{
  "name": "@durable-streams/conformance-tests",
  "description": "Conformance test suite for Durable Streams client and server implementations",
  "version": "0.4.0",
  "author": "Durable Stream contributors",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/durable-streams/durable-streams.git",
    "directory": "packages/conformance"
  },
  "bugs": {
    "url": "https://github.com/durable-streams/durable-streams/issues"
  },
  "keywords": [
    "conformance",
    "durable-streams",
    "testing",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/server/index.cjs",
  "module": "./dist/server/index.js",
  "types": "./dist/server/index.d.ts",
  "bin": {
    "conformance": "./dist/cli.js",
    "durable-streams-conformance": "./dist/cli.js",
    "durable-streams-conformance-dev": "./bin/conformance-dev.mjs"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server/index.d.ts",
        "default": "./dist/server/index.js"
      },
      "require": {
        "types": "./dist/server/index.d.cts",
        "default": "./dist/server/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client/index.d.ts",
        "default": "./dist/client/index.js"
      },
      "require": {
        "types": "./dist/client/index.d.cts",
        "default": "./dist/client/index.cjs"
      }
    },
    "./protocol": {
      "import": {
        "types": "./dist/client/protocol.d.ts",
        "default": "./dist/client/protocol.js"
      },
      "require": {
        "types": "./dist/client/protocol.d.cts",
        "default": "./dist/client/protocol.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "bin",
    "test-cases"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "client:run": "tsx src/cli.ts client --run ts",
    "client:run:verbose": "tsx src/cli.ts client --run ts --verbose",
    "client:run:elixir": "tsx src/cli.ts client --run ../client-elixir/run-conformance-adapter.sh",
    "client:run:python": "tsx src/cli.ts client --run ../client-py/run-conformance-adapter.sh",
    "client:bench": "tsx src/cli.ts client --bench ts"
  },
  "dependencies": {
    "@durable-streams/client": "0.2.6",
    "@durable-streams/server": "0.3.7",
    "fast-check": "^4.4.0",
    "tsx": "^4.19.2",
    "vitest": "^4.0.0",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "tsdown": "^0.9.0",
    "typescript": "^5.0.0"
  }
}
