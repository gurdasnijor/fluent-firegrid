{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": "../..",
    "paths": {
      "@durable-streams/conformance-tests/server": [
        "packages/conformance/src/server/index.ts"
      ],
      "@durable-streams/conformance-tests/*": [
        "packages/conformance/src/*"
      ]
    },
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["node"],
    "plugins": [
      {
        "name": "@effect/language-service",
        "namespaceImportPackages": ["effect", "@effect/platform"],
        "diagnosticSeverity": {
          "nodeBuiltinImport": "off",
          "processEnv": "suggestion",
          "processEnvInEffect": "suggestion"
        }
      }
    ]
  },
  "include": ["src/**/*.ts"]
}
