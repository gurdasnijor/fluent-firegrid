{
  "name": "effect-durable-streams",
  "version": "0.0.0",
  "description": "Effect-native Durable Streams server implementation.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "check": "pnpm run typecheck && pnpm run test",
    "diagnostics": "effect-language-service diagnostics --project tsconfig.json --severity error",
    "lint": "eslint .",
    "test": "vitest run --root ../.. --project effect-durable-streams",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.107.0",
    "@effect/rpc": "^0.75.1",
    "effect": "^3.21.2"
  },
  "devDependencies": {
    "@durable-streams/conformance-tests": "workspace:*",
    "@effect/vitest": "^0.29.0",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
