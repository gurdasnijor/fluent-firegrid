<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <AssemblyName>Firegrid.Store</AssemblyName>
    <RootNamespace>Firegrid.Store</RootNamespace>
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
    <DefineConstants>$(DefineConstants);FABLE_COMPILER</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="EffSharp" Version="*-*" />
    <PackageReference Include="Fable.Core" Version="5.1.0" />
    <PackageReference Include="Fable.Promise" Version="3.2.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../log/Effect.S2.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="src/Firegrid.Store/Types.fs" />
    <Compile Include="src/Firegrid.Store/JsJson.fs" />
    <Compile Include="src/Firegrid.Store/Naming.fs" />
    <Compile Include="src/Firegrid.Store/Runtime.fs" />
    <Compile Include="src/Firegrid.Store/ObjectState.fs" />
    <Compile Include="src/Firegrid.Store/WorkflowLog.fs" />
    <Compile Include="src/Firegrid.Store/Exports.fs" />
  </ItemGroup>

</Project>
