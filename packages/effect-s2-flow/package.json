{
  "name": "effect-s2-flow",
  "version": "0.0.0",
  "description": "Effect-native durable execution runtime over S2.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./capability-a-greeter": {
      "types": "./src/CapabilityAGreeter.ts",
      "default": "./src/CapabilityAGreeter.ts"
    }
  },
  "files": ["src", "README.md"],
  "scripts": {
    "build": "tsc",
    "diagnostics": "effect-language-service diagnostics --project tsconfig.json --strict",
    "host": "tsx src/HostMain.ts",
    "lint": "oxlint -f unix --config ../../.oxlintrc.json .",
    "test": "vitest run --root ../.. --project effect-s2-flow --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/opentelemetry": "4.0.0-beta.87",
    "@effect/platform-node": "4.0.0-beta.87",
    "@firegrid/observability": "workspace:*",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "effect-s2": "workspace:*",
    "effect": "4.0.0-beta.87"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@types/node": "^22.10.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
