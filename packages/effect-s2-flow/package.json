{
  "name": "effect-s2-flow",
  "version": "0.0.0",
  "description": "Effect-native runtime substrate for S2 flow orchestration.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./test-support": {
      "types": "./src/test-support/index.ts",
      "default": "./src/test-support/index.ts"
    }
  },
  "files": ["src", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "diagnostics": "effect-language-service diagnostics --project tsconfig.json --strict",
    "lint": "oxlint -f unix --config ../../.oxlintrc.json .",
    "test": "vitest run --root ../.. --project effect-s2-flow",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "effect": "4.0.0-beta.87"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
