{
  "name": "@firegrid/observability",
  "version": "0.0.0",
  "description": "chDB (embedded ClickHouse) driver for Effect SQL, plus an OTel span exporter onto the contrib otel_traces schema.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "diagnostics": "effect-language-service diagnostics --project tsconfig.json --strict",
    "lint": "oxlint -f unix --config ../../.oxlintrc.json .",
    "test": "vitest run --root ../.. --project observability",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "chdb": "^3.0.1",
    "effect": "4.0.0-beta.78"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@effect/vitest": "4.0.0-beta.78",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
