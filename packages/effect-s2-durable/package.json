{
  "name": "effect-s2-durable",
  "version": "0.0.0",
  "description": "An Effect-native durable execution engine over S2.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/ingress/client.ts",
      "default": "./src/ingress/client.ts"
    },
    "./catalog": {
      "types": "./src/catalog/index.ts",
      "default": "./src/catalog/index.ts"
    },
    "./engine": {
      "types": "./src/engine/index.ts",
      "default": "./src/engine/index.ts"
    },
    "./host": {
      "types": "./src/host/index.ts",
      "default": "./src/host/index.ts"
    },
    "./ingress": {
      "types": "./src/ingress/index.ts",
      "default": "./src/ingress/index.ts"
    },
    "./invocation": {
      "types": "./src/invocation/index.ts",
      "default": "./src/invocation/index.ts"
    }
  },
  "bin": {
    "effect-s2-durable-host": "./src/bin/host.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "diagnostics": "effect-language-service diagnostics --project tsconfig.json --strict",
    "lint": "oxlint -f unix --config ../../.oxlintrc.json .",
    "test": "vitest run --root ../.. --project effect-s2-durable",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.87",
    "effect": "4.0.0-beta.87",
    "effect-s2": "workspace:*",
    "effect-s2-stream-db": "workspace:*"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.87",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
