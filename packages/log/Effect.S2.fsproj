<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <AssemblyName>Effect.S2</AssemblyName>
    <RootNamespace>Effect.S2</RootNamespace>
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
    <DefineConstants>$(DefineConstants);FABLE_COMPILER</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="EffSharp" Version="*-*" />
    <PackageReference Include="Fable.Core" Version="5.1.0" />
    <PackageReference Include="Fable.Promise" Version="3.2.0" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="src/Effect.S2/Types.fs" />
    <Compile Include="src/Effect.S2/InternalSdk.fs" />
    <Compile Include="src/Effect.S2/S2.fs" />
  </ItemGroup>

</Project>
