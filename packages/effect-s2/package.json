{
  "name": "effect-s2",
  "version": "0.0.0",
  "description": "Effect-native facade for S2 durable streams.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./generated": {
      "types": "./src/generated/index.ts",
      "default": "./src/generated/index.ts"
    }
  },
  "files": [
    "src",
    "examples",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "diagnostics": "effect-language-service diagnostics --project tsconfig.json --strict",
    "generate:openapi": "openapi-ts -f openapi-ts.config.ts && pnpm --dir ../.. exec dprint fmt 'packages/effect-s2/src/generated/*.ts' && oxlint -f unix --config ../../.oxlintrc.json src/generated",
    "lint": "oxlint -f unix --config ../../.oxlintrc.json .",
    "test": "vitest run --root ../.. --project effect-s2",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@s2-dev/streamstore": "0.24.1",
    "@s2-dev/streamstore-patterns": "2.1.3",
    "effect": "4.0.0-beta.87"
  },
  "devDependencies": {
    "@effect/platform-node": "4.0.0-beta.87",
    "@effect/vitest": "4.0.0-beta.87",
    "@hey-api/openapi-ts": "0.99.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
