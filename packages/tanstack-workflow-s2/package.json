{
  "name": "@firegrid/tanstack-workflow-s2",
  "version": "0.0.0",
  "description": "S2-backed WorkflowExecutionStore for TanStack Workflow.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": ["src", "README.md"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "diagnostics": "effect-language-service diagnostics --project tsconfig.json --strict",
    "lint": "oxlint -f unix --config ../../.oxlintrc.json .",
    "test": "vitest run --root ../.. --project tanstack-workflow-s2 --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/workflow-core": "workspace:*",
    "@tanstack/workflow-runtime": "workspace:*",
    "effect": "4.0.0-beta.87",
    "effect-s2": "workspace:*"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
