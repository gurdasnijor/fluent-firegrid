{
  "name": "@firegrid/fluent",
  "version": "0.0.0",
  "description": "Restate-like fluent API over the Firegrid TanStack/S2 durable runtime.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./state": {
      "types": "./src/state.ts",
      "default": "./src/state.ts"
    },
    "./http": {
      "types": "./src/http.ts",
      "default": "./src/http.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {},
  "dependencies": {
    "@firegrid/core": "workspace:*",
    "@firegrid/runtime": "workspace:*",
    "@marcbachmann/cel-js": "^7.6.1",
    "effect": "4.0.0-beta.87"
  }
}
