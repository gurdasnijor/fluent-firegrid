{
  "name": "@firegrid/fluent",
  "version": "0.0.0",
  "description": "Restate-like fluent API over the Firegrid TanStack/S2 durable runtime.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./state": {
      "types": "./src/state.ts",
      "default": "./src/state.ts"
    },
    "./http": {
      "types": "./src/http.ts",
      "default": "./src/http.ts"
    },
    "./clients": {
      "types": "./src/clients/index.ts",
      "default": "./src/clients/index.ts"
    },
    "./runtime": {
      "types": "./src/runtime/index.ts",
      "default": "./src/runtime/index.ts"
    },
    "./s2": {
      "types": "./src/adapters/s2/index.ts",
      "default": "./src/adapters/s2/index.ts"
    },
    "./testing": {
      "types": "./src/testing/index.ts",
      "default": "./src/testing/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "diagnostics": "effect-language-service diagnostics --project tsconfig.diagnostics.json --strict",
    "lint": "oxlint -f unix --config ../../.oxlintrc.json .",
    "test": "vitest run --root ../.. --project fluent --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@firegrid/core": "workspace:*",
    "@firegrid/log": "workspace:*",
    "effect": "4.0.0-beta.87"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
