{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "packages/*": {
      "project": [
        "src/**/*.ts!",
        "test/**/*.ts"
      ]
    },
    "packages/fluent-acp-process": {
      "project": [
        "src/**/*.ts!",
        "test/**/*.ts"
      ]
    },
    "packages/effect-s2": {
      "entry": [
        "examples/**/*.ts!"
      ],
      "project": [
        "src/**/*.ts!",
        "test/**/*.ts",
        "examples/**/*.ts!"
      ]
    },
    "packages/effect-s2-stream-db": {
      "entry": [
        "test/usage.ts"
      ],
      "project": [
        "src/**/*.ts!",
        "test/**/*.ts"
      ]
    },
    "packages/effect-s2-durable": {
      "entry": [
        "test/types.ts"
      ],
      "project": [
        "src/**/*.ts!",
        "test/**/*.ts"
      ]
    }
  }
}
