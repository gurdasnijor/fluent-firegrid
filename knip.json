{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "packages/*": {
      "project": [
        "src/**/*.ts!",
        "proofs/**/*.ts!",
        "test/**/*.ts"
      ]
    },
    "packages/effect-s2-flow": {
      "project": [
        "src/**/*.ts!",
        "test/**/*.ts"
      ]
    },
    "packages/verification": {
      "entry": [
        "proofs/main.ts!",
        "proofs/effect-s2-flow-proof-host.ts!"
      ],
      "project": [
        "src/**/*.ts!",
        "proofs/**/*.ts!",
        "test/**/*.ts"
      ]
    },
    "packages/fluent-acp-process": {
      "project": [
        "src/**/*.ts!",
        "proofs/**/*.ts!",
        "test/**/*.ts"
      ]
    },
    "packages/effect-s2": {
      "entry": [
        "examples/**/*.ts!"
      ],
      "project": [
        "src/**/*.ts!",
        "test/**/*.ts",
        "examples/**/*.ts!"
      ]
    }
  }
}
