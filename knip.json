{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": [
    "@typespec/http-server-js",
    "@typespec/rest",
    "tslib"
  ],
  "workspaces": {
    "packages/fluent-runtime": {
      "entry": [
        "test/**/*.test.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    },
    "packages/fluent-acp-process": {
      "entry": [
        "test/**/*.test.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    },
    "packages/durable-streams-protocol": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/effect-durable-client": {
      "entry": [
        "test/**/*.test.ts",
        "test/bench/**/*.bench.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    },
    "packages/effect-durable-execution": {
      "entry": [
        "test/**/*.test.ts",
        "bench/**/*.bench.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts",
        "bench/**/*.ts"
      ]
    },
    "packages/effect-durable-streams": {
      "entry": [
        "test/**/*.test.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    },
    "packages/conformance": {
      "entry": [
        "bin/**/*.mjs"
      ],
      "project": [
        "src/**/*.ts",
        "bin/**/*.mjs"
      ]
    },
    "packages/firelab": {
      "entry": [
        "src/index.ts",
        "src/bin/**/*.ts",
        "src/simulations/*/index.ts",
        "src/observability/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    }
  },
  "ignoreIssues": {
    "packages/conformance/src/client/benchmark-scenarios.ts": [
      "exports",
      "types"
    ],
    "packages/conformance/src/client/benchmark-runner.ts": [
      "types"
    ],
    "packages/conformance/src/client/test-cases.ts": [
      "exports",
      "types"
    ],
    "packages/effect-durable-client/src/Client.ts": [
      "types"
    ],
    "packages/conformance/src/server/consumer-dsl.ts": [
      "exports",
      "types"
    ],
    "packages/conformance/src/server/consumer-tests.ts": [
      "types"
    ],
    "packages/conformance/src/server/pull-wake-dsl.ts": [
      "exports",
      "types"
    ],
    "packages/conformance/src/server/pull-wake-tests.ts": [
      "types"
    ]
  },
  "ignore": [
    "repos/**"
  ],
  "ignoreWorkspaces": []
}
