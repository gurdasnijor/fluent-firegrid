{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreIssues": {
    "packages/fluent/src/clients/base.ts": ["duplicates"],
    "packages/fluent/src/clients.ts": ["duplicates"],
    "packages/fluent/src/runtime/types.ts": ["types"]
  },
  "workspaces": {
    "packages/core": {
      "project": ["src/**/*.ts!"]
    },
    "packages/fluent": {
      "project": ["src/**/*.ts!", "test/**/*.ts"]
    },
    "packages/log": {
      "entry": ["examples/**/*.ts!"],
      "project": ["src/**/*.ts!", "test/**/*.ts", "examples/**/*.ts!"]
    },
    "packages/trace": {
      "project": ["src/**/*.ts!", "test/**/*.ts"]
    },
    "apps/acp-process": {
      "project": ["src/**/*.ts!", "test/**/*.ts"]
    },
    "apps/proofs": {
      "project": ["src/**/*.ts!", "proofs/**/*.ts!", "test/**/*.ts"]
    },
    "apps/examples/full-stack-service": {
      "project": ["src/**/*.ts!", "examples/**/*.ts!", "test/**/*.ts"]
    }
  }
}
