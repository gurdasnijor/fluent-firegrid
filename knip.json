{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": [
    "@typespec/http-server-js",
    "@typespec/rest",
    "tslib"
  ],
  "workspaces": {
    "packages/fluent-acp-process": {
      "entry": [
        "test/**/*.test.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    },
    "packages/effect-s2": {
      "entry": [
        "test/**/*.test.ts",
        "examples/**/*.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts",
        "examples/**/*.ts"
      ]
    },
    "packages/effect-s2-stream-db": {
      "entry": [
        "test/**/*.test.ts",
        "test/usage.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    }
  },
  "ignoreWorkspaces": [
    "packages/firelab"
  ]
}
