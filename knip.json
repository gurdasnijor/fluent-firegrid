{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": [
    "@typespec/http-server-js",
    "@typespec/rest",
    "tslib",
    "tsx"
  ],
  "ignoreUnresolved": [
    "summary"
  ],
  "workspaces": {
    "packages/fluent-acp-process": {
      "entry": [
        "src/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/effect-s2": {
      "entry": [
        "src/index.ts",
        "examples/**/*.ts"
      ],
      "project": [
        "src/**/*.ts",
        "examples/**/*.ts"
      ]
    },
    "packages/effect-s2-stream-db": {
      "entry": [
        "src/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/effect-s2-durable": {
      "entry": [
        "src/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/durable-cucumber": {
      "entry": [
        "src/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ],
      "ignoreDependencies": [
        "@cucumber/compatibility-kit"
      ]
    }
  }
}
