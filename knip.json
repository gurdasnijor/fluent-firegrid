{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "packages/fluent-runtime": {
      "entry": [
        "test/**/*.test.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    },
    "packages/fluent-acp-process": {
      "entry": [
        "test/**/*.test.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    },
    "packages/fluent-firegrid": {
      "entry": [
        "test/**/*.test.ts",
        "bench/**/*.bench.ts",
        "examples/tutorial/src/server.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts",
        "bench/**/*.ts",
        "examples/**/*.ts"
      ]
    },
    "packages/firelab": {
      "entry": [
        "src/index.ts",
        "src/bin/**/*.ts",
        "src/simulations/*/index.ts",
        "src/observability/index.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    }
  },
  "ignore": [],
  "ignoreWorkspaces": []
}
