{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreIssues": {
    "packages/fluent-firegrid/src/clients.ts": ["duplicates"]
  },
  "workspaces": {
    "packages/effect-s2": {
      "entry": ["examples/**/*.ts!"],
      "project": ["src/**/*.ts!", "test/**/*.ts", "examples/**/*.ts!"]
    },
    "packages/fluent-acp-process": {
      "project": ["src/**/*.ts!", "test/**/*.ts"]
    },
    "packages/fluent-firegrid": {
      "project": ["src/**/*.ts!", "test/**/*.ts"]
    },
    "packages/fluent-firegrid-http": {
      "project": ["src/**/*.ts!", "test/**/*.ts"]
    },
    "packages/fluent-firegrid-s2": {
      "project": ["src/**/*.ts!"]
    },
    "packages/observability": {
      "project": ["src/**/*.ts!", "test/**/*.ts"]
    },
    "packages/tanstack-workflow-core": {
      "project": ["src/**/*.ts!"]
    },
    "packages/tanstack-workflow-runtime": {
      "project": ["src/**/*.ts!"]
    },
    "packages/tanstack-workflow-s2": {
      "project": ["src/**/*.ts!"]
    },
    "packages/verification": {
      "entry": ["proofs/main.ts!"],
      "project": ["src/**/*.ts!", "proofs/**/*.ts!", "test/**/*.ts"]
    }
  }
}
