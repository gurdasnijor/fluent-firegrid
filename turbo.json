{
  "$schema": "https://turbo.build/schema.json",
  "cacheDir": ".turbo/cache",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "typecheck"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["src/**", "test/**", "examples/**", "tsconfig.json", "../../tsconfig.json"],
      "outputs": []
    },
    "diagnostics": {
      "dependsOn": ["^diagnostics"],
      "inputs": [
        "src/**",
        "test/**",
        "examples/**",
        "tsconfig.json",
        "../../tsconfig.json"
      ],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint", "//#lint:root", "//#lint:dead", "//#lint:dup", "//#lint:deps"],
      "inputs": [
        "src/**",
        "test/**",
        "examples/**",
        "tsconfig.json",
        "../../.oxlintrc.json",
        "../../dprint.json",
        "../../tools/oxc/**",
        "../../tsconfig.json"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "test/**", "examples/**", "tsconfig.json", "../../vitest.config.ts"],
      "passThroughEnv": ["S2_LITE_BIN"],
      "outputs": []
    },
    "check": {
      "dependsOn": ["lint", "typecheck", "diagnostics", "test"],
      "outputs": []
    },
    "//#lint:dead": {
      "inputs": ["knip.json", "package.json", "packages/**/package.json", "packages/**/src/**", "packages/**/test/**"],
      "cache": false
    },
    "//#lint:dup": {
      "inputs": ["packages/*/src/**", ".jscpd.json"],
      "outputs": []
    },
    "//#lint:deps": {
      "inputs": ["packages/**", ".dependency-cruiser.cjs", "tsconfig.json"],
      "outputs": []
    },
    "//#lint:root": {
      "inputs": [
        ".oxlintrc.json",
        "dprint.json",
        "package.json",
        "tools/oxc/**",
        "tsconfig.json"
      ],
      "outputs": []
    }
  }
}
