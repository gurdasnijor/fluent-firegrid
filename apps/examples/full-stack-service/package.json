{
  "name": "@firegrid/example-full-stack-service",
  "version": "0.0.0",
  "description": "Node HTTP server binding for S2-backed @firegrid/fluent definitions.",
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./examples/durable-webhook": {
      "types": "./examples/durable-webhook.ts",
      "default": "./examples/durable-webhook.ts"
    },
    "./examples/ordering": {
      "types": "./examples/ordering.ts",
      "default": "./examples/ordering.ts"
    }
  },
  "files": ["src", "examples", "README.md"],
  "scripts": {
    "build": "tsc",
    "diagnostics": "effect-language-service diagnostics --project tsconfig.json --strict",
    "lint": "oxlint -f unix --config ../../../.oxlintrc.json .",
    "test": "vitest run --root ../../.. --project example-full-stack-service --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@firegrid/fluent": "workspace:*"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@types/node": "^22.10.0",
    "effect": "4.0.0-beta.87",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
