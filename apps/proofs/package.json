{
  "name": "@firegrid/proofs",
  "version": "0.0.0",
  "description": "Trace-native verification harness for Firegrid distributed-system properties.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "proofs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "diagnostics": "effect-language-service diagnostics --project tsconfig.json --strict",
    "lint": "oxlint -f unix --config ../../.oxlintrc.json .",
    "proofs": "tsx proofs/main.ts proof run all",
    "test": "vitest run --root ../.. --project proofs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/opentelemetry": "4.0.0-beta.87",
    "@effect/platform-node": "4.0.0-beta.87",
    "@firegrid/fluent": "workspace:*",
    "@firegrid/log": "workspace:*",
    "@firegrid/trace": "workspace:*",
    "@opentelemetry/api-logs": "^0.208.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-logs": "^0.208.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "effect": "4.0.0-beta.87"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@types/node": "^22.10.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
